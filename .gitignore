# Binaries & build output
/yata
yata.exe
yata.exe~
*.exe
static/dashboard.js
web/dist/
dist/
dev.ps1

# Editor / tooling
.claude/
.vscode/

# User data — never commit credentials or local databases
config.json
*.db
*.db-wal
*.db-shm
data/

# Rolling log files (may contain paths/usernames — never commit)
yata.log
yata.log.*
*.log

# Config backups (contain credentials — never commit)
backups/

# Node
web/node_modules/

# Dev-only saved tracker pages (large, contain personal profile data)
reference/

# Dev tools
internal/scrape/profile_test.go
tools/scrapetest/
tools/apiprobe/
tools/genversions/
tools/seedtest/

# Self-hosted Font Awesome (e.g. Pro) — licensed assets, must NOT ship in the public repo
static/fontawesome/


*.md
# Ships publicly: README + CHANGELOG (CHANGELOG is also read by the release
# workflow for the GitHub Release notes) + the API reference (linked from the
# README and the in-app Integrations tab). Other docs/*.md stay internal.
!/README.md
!/CHANGELOG.md
!/docs/API.md

# OS noise
.DS_Store
Thumbs.db
