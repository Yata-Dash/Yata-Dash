{
  "schema_version": 1,
  "key": "retroflix",
  "name": "RetroFlix",
  "abbr": "RF",
  "url": "https://retroflix.net",
  "aliases": ["https://retroflix.club"],
  "type": "custom",
  "last_updated": "2026-07-16",
  "approved_by": {
    "name": "ovrflo",
    "role": "Special Effects",
    "date": "2026-07-15"
  },
  "api": {
    "path": "/api/me",
    "auth_method": "api_key_header",
    "field_map": {
      "username": "username",
      "id": "user_id",
      "ratio": "ratio",
      "created_at": "join_date",
      "seed_bonus": "bonus_points",
      "snatched_count": "snatched",
      "average_seed_time": "avg_seed_time",
      "seed_time": "total_seedtime",
      "hit_and_run_count": "hit_and_runs",
      "invites": "invites"
    },
    "byte_fields": {
      "uploaded": "uploaded",
      "downloaded": "downloaded"
    },
    "buffer_from_bytes": true,
    "bool_fields": {
      "unread_private_message_count": "unread_mail"
    },
    "class_field": "class",
    "class_map": {
      "0": "Film Dummy",
      "1": "Film Stunt",
      "2": "Movie Lover",
      "3": "Cinema Addicted",
      "4": "Film Critic",
      "5": "VIP",
      "6": "Retiree",
      "7": "Uploader",
      "8": "Director",
      "9": "Producer",
      "10": "Executive Producer"
    },
    "api_key_hint": "Your RetroFlix API token (Bearer/JWT) from your account settings. Works on both retroflix.net and retroflix.club."
  },
  "scrape": {
    "disable_scraping": true,
    "profile_path": "/userdetails.php?id={id}",
    "labels": {
      "share ratio": "ratio",
      "seed avg.": "avg_seed_time",
      "seeding time": "total_seedtime",
      "hit&run": "hit_and_runs",
      "karma points": "bonus_points",
      "invitations": "invites",
      "class": "group"
    }
  },
  "invite_requirements": {
    "min_class": "Movie Lover"
  },
    "rules": {
    "min_ratio": 0.4
  },
  "groups": [
    {
      "name": "Film Dummy",
      "style": {
        "color": "#708090",
        "icon": "fas fa-thumbs-down"
      },
      "requirements": {
        "description": "Demotion class — improve your ratio within 30 days or be banned."
      }
    },
    {
      "name": "Film Stunt",
      "style": {
        "color": "#A9A9A9",
        "icon": "fas fa-person-falling"
      },
      "requirements": {}
    },
    {
      "name": "Movie Lover",
      "style": {
        "color": "#daa520",
        "icon": "fas fa-heart"
      },
      "requirements": {
        "min_downloaded": "50 GB",
        "min_ratio": 1.05,
        "min_age": "4W"
      },
      "perks": [
        { "icon": "fas fa-trophy", "label": "View Top Ten" },
        { "icon": "fas fa-seedling", "label": "Ask for reseeds" }
      ]
    },
    {
      "name": "Cinema Addicted",
      "style": {
        "color": "#008b8b",
        "icon": "fas fa-ticket"
      },
      "requirements": {
        "min_downloaded": "120 GB",
        "min_ratio": 1.55,
        "min_age": "8W"
      },
      "perks": [
        { "icon": "fas fa-shield", "label": "Never deleted while parked" }
      ]
    },
    {
      "name": "Film Critic",
      "style": {
        "color": "#00bfff",
        "icon": "fas fa-pen-nib"
      },
      "requirements": {
        "min_downloaded": "300 GB",
        "min_ratio": 2.05,
        "min_age": "15W"
      },
      "perks": [
        { "icon": "fas fa-folder-tree", "label": "View torrent structure" },
        { "icon": "fas fa-image", "label": "Set a userbar" },
        { "icon": "fas fa-shield", "label": "Never deleted while parked" }
      ]
    },
    {
      "name": "VIP",
      "style": {
        "color": "#009f00",
        "icon": "fas fa-gem",
        "sparkle": true
      },
      "requirements": {
        "description": "Assigned by mods at their discretion to users who contribute something special to the site."
      }
    },
    {
      "name": "Retiree",
      "style": {
        "color": "#1cc6d5",
        "icon": "fas fa-umbrella-beach"
      },
      "requirements": {
        "description": "Former staff members. Granted by the Executive Producer."
      }
    },
    {
      "name": "Uploader",
      "style": {
        "color": "#2ECC71",
        "icon": "fas fa-upload"
      },
      "requirements": {
        "description": "Appointed by Director/Executive Producer. Can upload torrents, view anonymous uploaders and banned torrents."
      }
    },
    {
      "name": "Director",
      "style": {
        "color": "#6495ed",
        "icon": "fas fa-clapperboard"
      },
      "requirements": {
        "description": "RetroFlix Moderator."
      }
    },
    {
      "name": "Producer",
      "style": {
        "color": "#4b0082",
        "icon": "fas fa-user-tie"
      },
      "requirements": {
        "description": "RetroFlix Administrator."
      }
    },
    {
      "name": "Executive Producer",
      "style": {
        "color": "#ff0000",
        "icon": "fas fa-crown"
      },
      "requirements": {
        "description": "RetroFlix SysOp."
      }
    }
  ]
}
