{
  "schema_version": 1,
  "key": "btn",
  "name": "BroadcastTheNet",
  "abbr": "BTN",
  "url": "https://broadcasthe.net",
  "type": "custom",
  "last_updated": "2026-07-22",
  "scrape": {
    "disable_scraping": true
  },
  "api": {
    "base_url": "https://api.broadcasthe.net",
    "path": "/",
    "auth_method": "api_key_json_rpc",
    "json_rpc_method": "userInfo",
    "field_map": {
      "result.Username": "username",
      "result.Class": "group",
      "result.Bonus": "bonus_points",
      "result.Invites": "invites",
      "result.HnR": "hit_and_runs",
      "result.Lumens": "lumens"
    },
    "sum_fields": {
      "snatched": ["result.Snatches", "result.UploadsSnatched"]
    },
    "byte_fields": {
      "result.Upload": "uploaded",
      "result.Download": "downloaded"
    },
    "sum_bytes_fields": {
      "total_transfer": ["result.Upload", "result.Download"]
    },
    "unix_fields": {
      "result.JoinDate": "join_date"
    }
  },
  "rules": {
    "min_seed_days_episode": 1,
    "min_seed_days_season": 5,
    "note": "Ratioless: meet the seed-time rule or a 1:1 torrent ratio within 2 weeks, while seeding at least once every 12 hours. H&R applies from 10% downloaded. Any H&R stops bonus earnings and promotions; more than 15 disables the account."
  },
  "invite_requirements": {
    "min_class": "Elite",
    "note": "Elite members can send invites purchased from the Lumens Store."
  },
  "groups": [
    {
      "name": "Sheep",
      "style": {},
      "requirements": { "description": "Restricted user class that members should avoid." }
    },
    {
      "name": "User",
      "style": {},
      "requirements": { "note": "Default class for new members." }
    },
    {
      "name": "Member",
      "style": {},
      "requirements": {
        "min_total_transfer": "100 GB",
        "min_bonus_points": 100000,
        "min_age": "2W",
        "min_counts": [
          { "field": "snatched", "count": 100, "label": "Snatches" }
        ],
        "note": "Promotion costs 100,000 bonus points. Classes must be purchased sequentially; H&Rs block promotion."
      }
    },
    {
      "name": "Power User",
      "style": {},
      "requirements": {
        "min_total_transfer": "250 GB",
        "min_bonus_points": 250000,
        "min_age": "1M",
        "min_counts": [
          { "field": "snatched", "count": 250, "label": "Snatches" }
        ],
        "note": "Promotion costs 250,000 bonus points. Classes must be purchased sequentially; H&Rs block promotion."
      },
      "perks": [
        { "icon": "", "label": "Access Power User forum" },
        { "icon": "", "label": "Access Official and Unofficial Invites forums" },
