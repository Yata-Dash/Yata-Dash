{
  "schema_version": 1,
  "key": "orpheus",
  "name": "Orpheus",
  "abbr": "OPS",
  "url": "https://orpheus.network",
  "type": "gazelle_json",
  "last_updated": "2026-07-22",
  "api": {
    "api_key_hint": "User Settings → API Keys. Paste the value as 'token <key>' (including the word token) — Orpheus deprecates the bare-key Authorization header."
  },
  "scrape": {
    "disable_scraping": true
  },
  "rules": {
    "note": "Required ratio is calculated dynamically per account from data downloaded and seeding activity (0.00–0.60, rising with more downloaded and falling with more concurrent seeding; see the live required ratio stat). Falling below required ratio starts a 2-week ratio watch; failing to clear it revokes leeching privileges (account stays enabled). The first 5 GB downloaded is exempt."
  },
  "groups": [
    {
      "name": "User",
      "style": {},
      "requirements": {
        "description": "Standard class for all new members."
      }
    },
    {
      "name": "Member",
      "style": {},
      "requirements": {
        "min_uploaded": "10 GiB",
        "min_ratio": 0.7,
        "min_age": "1W",
        "note": "Demoted to User when ratio drops below 0.60."
      },
      "perks": [
        { "icon": "", "label": "Advanced Search" },
        { "icon": "", "label": "Make requests" },
        { "icon": "", "label": "Purchase invites" },
        { "icon": "", "label": "Basic torrent editing privileges" },
        { "icon": "", "label": "Auto-subscribe to forum threads" }
      ]
    },
    {
      "name": "Power User",
      "style": {},
      "requirements": {
        "min_uploaded": "25 GiB",
        "min_ratio": 1.05,
        "min_age": "2W",
        "min_uploads": 5,
        "note": "Demoted to Member when ratio drops below 0.95, or torrent count falls below 5."
      },
      "perks": [
        { "icon": "", "label": "Immune to inactivity pruning" },
        { "icon": "", "label": "Torrent notification system" },
        { "icon": "", "label": "Collage creation (non-personal)" },
        { "icon": "", "label": "RSS feed access" },
        { "icon": "", "label": "Use the collector" },
        { "icon": "", "label": "View upload/download/bonus history stats" },
        { "icon": "", "label": "Power User forums and IRC channels" }
      ]
    },
    {
      "name": "Elite",
      "style": {},
      "requirements": {
        "min_uploaded": "100 GiB",
        "min_ratio": 1.05,
        "min_age": "4W",
        "min_uploads": 50,
        "note": "Demoted to Member when ratio drops below 0.95."
      },
      "perks": [
        { "icon": "", "label": "Invitations and Elite forums/IRC" },
        { "icon": "", "label": "Edit torrents" },
        { "icon": "", "label": "Rename personal collages" }
