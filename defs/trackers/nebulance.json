{
  "schema_version": 1,
  "key": "nebulance",
  "name": "Nebulance",
  "abbr": "NBL",
  "url": "https://nebulance.io",
  "type": "custom",
  "last_updated": "2026-07-21",
  "api": {
    "path": "/api.php?action=user&method=getuserinfo&type=username&user={username}",
    "auth_method": "api_key_query",
    "api_key_param": "api_key",
    "success_field": "status",
    "success_value": "success",
    "field_map": {
      "response.Username": "username",
      "response.Class": "group",
      "response.JoinDate": "join_date",
      "response.SeedCount": "seeding",
      "response.HnR": "hit_and_runs",
      "response.Invites": "invites",
      "response.Grabbed": "grabbed",
      "response.Snatched": "snatched",
      "response.ForumPosts": "forum_posts"
    },
    "byte_fields": {
      "response.Uploaded": "uploaded",
      "response.Downloaded": "downloaded"
    },
    "buffer_from_bytes": true,
    "ratio_from_bytes": true,
    "api_key_hint": "User Settings → API Keys. Create a key with permission to access your own user information."
  },
  "scrape": {
    "disable_scraping": true
  },
  "rules": {
    "min_seed_days_episode": 1,
    "min_seed_days_season": 5
  },
  "invite_requirements": {
    "min_class": "Ensign",
    "note": "Ensign grants access to the recruitment forum."
  },
